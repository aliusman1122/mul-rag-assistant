# =============================================================================
# FILE: .gitignore
# =============================================================================

# =============================================================================
# 🔐 SENSITIVE FILES -
# =============================================================================
.env                  # API keys aur secrets
.env.local
*.key
*.pem
*.p12

# =============================================================================
# 🗄️ GENERATED DATA - 
# =============================================================================
chroma_db/            # Vector database (locally generate hota hai)
data/scraped/         # Scraped data (script se generate hoga)
data/processed/       # Processed data
data/temp/            # Temporary files
data/chat_history.json

# =============================================================================
# 🐍 PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# =============================================================================
# 🌿 VIRTUAL ENVIRONMENT
# =============================================================================
venv/
env/
ENV/
.venv/

# =============================================================================
# 📓 JUPYTER NOTEBOOKS (checkpoints)
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
# 🖥️ OS FILES
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# 📝 LOGS
# =============================================================================
logs/
*.log

# =============================================================================
# 🔧 IDE FILES
# =============================================================================
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
# 📦 HUGGINGFACE CACHE
# =============================================================================
.cache/

# =============================================================================
# ✅ KYA INCLUDE KARNA HAI (PDFs chahiye GitHub par)
# =============================================================================
# data/pdfs/*.pdf   <-- Uncomment agar PDFs GitHub par chahiye